{
  "manifest_version": 3,
  "name": "Instant Selection Translator",
  "version": "1.0.0",
  "description": "Translate selected text instantly to your target language.",
  "permissions": ["storage"],
  "host_permissions": ["https://api-free.deepl.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
